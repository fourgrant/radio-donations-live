# Copy to .env for local development (the dotenv gem is NOT loaded in production;
# on Render these are set in the dashboard / render.yaml instead).

# ---- Required ----
# Your Bloomerang Fundraising / Qgiv reporting API token.
# Must be a permanent "all forms" token so every donation form is included.
QGIV_API_TOKEN=

# Shown in the page header and browser title.
STATION_NAME=Community Radio

# ---- Dashboard login (HTTP Basic Auth on the public board) ----
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=changeme

# ---- Optional ----
# IANA timezone used to localize donation timestamps.
STATION_TIMEZONE=America/New_York

# Public hostname, e.g. donations.mystation.org (drives host + WebSocket origin checks).
APP_HOST=

# Fundraising goal in whole dollars. When set, a progress bar fills toward it.
# Leave blank to hide the goal bar.
GOAL_AMOUNT=

# Only count donations on/after this date toward the goal (YYYY-MM-DD).
# Useful to scope the bar to the current drive.
DRIVE_START_DATE=

# The exact Qgiv donation-form question treated as the on-air shoutout.
# Other custom fields still display regardless of this value.
SHOUTOUT_QUESTION=Want to leave a shoutout for a DJ or show?

# Optional branding.
STATION_LOGO_URL=
ACCENT_COLOR=#F5BD47

# Redis (local dev uses the in-process async adapter, so this is only needed
# if you run Sidekiq locally).
# REDIS_URL=redis://localhost:6379/1
